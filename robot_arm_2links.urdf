<?xml version="1.0"?>
<robot name="custom_2link_arm">

  <material name="petg_grey">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>
  <material name="motor_black">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="gripper_red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.076"/>
      </geometry>
      <material name="petg_grey"/>
      <origin xyz="0 0 0.02"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.076"/>
      </geometry>
      <origin xyz="0 0 0.02"/>
    </collision>
    <inertial>
      <mass value="2.0"/> <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="waist_joint" type="revolute">
    <parent link="base_link"/>
    <child link="waist_link"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.04"/> <limit lower="-3.14" upper="3.14" effort="5.0" velocity="2.0"/>
  </joint>

  <link name="waist_link">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.076"/>
      </geometry>
      <material name="petg_grey"/>
      <origin xyz="0 0 0.02"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.076"/>
      </geometry>
      <origin xyz="0 0 0.02"/>
    </collision>
    <inertial>
      <mass value="0.48"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="waist_link"/>
    <child link="link_1"/>
    <axis xyz="0 1 0"/> 
    <origin xyz="0 0 0.06"/> <limit lower="-2.0" upper="2.0" effort="6.0" velocity="1.5"/>
  </joint>

  <link name="link_1">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.13"/> 
      </geometry>
      <material name="petg_grey"/>
      <origin xyz="0 0 0.065" rpy="0 0 0"/> 
    </visual>
    <visual>
        <geometry>
            <cylinder length="0.05" radius="0.025"/>
        </geometry>
        <material name="motor_black"/>
        <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.04 0.13"/>
      </geometry>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.53"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 0 0.13"/> <limit lower="-2.5" upper="2.5" effort="5.0" velocity="1.5"/>
  </joint>

  <link name="link_2">
    <visual>
      <geometry>
        <box size="0.035 0.035 0.13"/> 
      </geometry>
      <material name="petg_grey"/>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
    </visual>
    <visual>
        <geometry>
            <cylinder length="0.05" radius="0.025"/>
        </geometry>
        <material name="motor_black"/>
        <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.035 0.035 0.13"/>
      </geometry>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.53"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="wrist_pitch_joint" type="revolute">
    <parent link="link_2"/>
    <child link="gripper_base"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 0 0.13"/> <limit lower="-1.57" upper="1.57" effort="3.0" velocity="2.0"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <geometry>
        <box size="0.08 0.03 0.04"/>
      </geometry>
      <material name="motor_black"/>
      <origin xyz="0 0 0.02"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.03 0.04"/>
      </geometry>
      <origin xyz="0 0 0.02"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="finger_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="finger_left"/>
    <axis xyz="1 0 0"/>
    <origin xyz="0 0 0.04"/>
    <limit lower="0.0" upper="0.01" effort="10.0" velocity="0.5"/>
  </joint>

  <link name="finger_left">
    <visual>
      <geometry>
        <box size="0.005 0.02 0.04"/>
      </geometry>
      <material name="gripper_red"/>
      <origin xyz="-0.01 0 0.02"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.005 0.02 0.04"/>
      </geometry>
      <origin xyz="-0.01 0 0.02"/>
    </collision>
    <inertial>
       <mass value="0.02"/>
       <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="finger_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="finger_right"/>
    <axis xyz="1 0 0"/>
    <origin xyz="0 0 0.04"/>
    <limit lower="-0.01" upper="0.0" effort="10.0" velocity="0.5"/>
  </joint>

  <link name="finger_right">
    <visual>
      <geometry>
        <box size="0.005 0.02 0.04"/>
      </geometry>
      <material name="gripper_red"/>
      <origin xyz="0.01 0 0.02"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.005 0.02 0.04"/>
      </geometry>
      <origin xyz="0.01 0 0.02"/>
    </collision>
    <inertial>
       <mass value="0.02"/>
       <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

</robot>